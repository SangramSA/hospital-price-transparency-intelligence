# Copy to .env and adjust if the app or pipeline reads environment variables.
#
# Optional: default path for combined export (e.g. Streamlit sidebar default).
# HPT_COMBINED_DATA_PATH=data/processed/combined.csv
#
# Optional: raw download root (default data/raw).
# HPT_RAW_DIR=data/raw
#
# Optional: HTTP timeout seconds for MRF downloads and cms-hpt.txt fetches.
# HPT_HTTP_TIMEOUT_SEC=120
#
# Optional: max retries for transient HTTP errors (default 3).
# HPT_HTTP_MAX_RETRIES=3
#
# Optional: override path to hospitals.yaml (default config/hospitals.yaml).
# HPT_HOSPITALS_CONFIG=config/hospitals.yaml
#
# Optional: HTTP User-Agent (default is browser-shaped for CDN/WAF compatibility).
# Set explicitly if you need a named bot string for policy/audit.
# HPT_HTTP_USER_AGENT=Mozilla/5.0 ...
