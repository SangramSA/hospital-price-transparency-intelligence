# Local session handoff for agents (regenerate as needed; not source of truth in repo)
docs/next-session-handoff.md

# Assessment / working materials (keep locally; not in version control)
docs/Sangram_Data Engineering Assessment_March 2026.pdf
docs/hospital_data_discovery_and_pipeline_reference.docx
docs/MRF URL Comparison.xlsx
data/Medicare Inpatient Hospitals - by Provider and Service Data Dictionary.pdf

# Large MRF artifacts (keep directory placeholders)
data/raw/**/*
!data/raw/.gitkeep

# Generated pipeline outputs (keep directory placeholders)
data/processed/**/*
!data/processed/.gitkeep

# Silver-layer canonical JSONL and batch reports (regenerate via extract)
data/silver/**/*
!data/silver/.gitkeep

# Local scratch JSON at repo root (CSV profiling, schema summaries — not source)
/tmp_*.json
